# ============================================================
# beauty-swarm — Environment Variables
# Copy to .env and fill in real values.
# ============================================================

# ---- Required ----
# Anthropic API key (read implicitly by @anthropic-ai/sdk).
ANTHROPIC_API_KEY=sk-ant-...

# Admin HTTP header auth (X-Admin-Key). Must be >=32 chars.
# Generate: openssl rand -hex 32
ADMIN_KEY=change-me-to-a-32-plus-char-random-string

# PostgreSQL connection string.
DATABASE_URL=postgres://user:pass@localhost:5432/beauty_swarm

# ---- Optional ----
# HTTP port (default: 3000)
PORT=3000

# Bind address. Default 127.0.0.1 — only localhost can reach /compose (unauthenticated).
# Set 0.0.0.0 ONLY behind a reverse proxy that adds auth + rate limit on /compose.
HOST=127.0.0.1

# CORS allow-list. Comma-separated origins. Default "*" (wide open — set this in prod).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Guardrail default. One of: trust | brand | hybrid (default: hybrid).
GUARDRAIL_MODE=hybrid

# Opt-in: allow /compose to be publicly reachable without auth when HOST=0.0.0.0.
# Not implemented as a hard gate yet — acts as documentation signal.
# COMPOSE_PUBLIC=false

# Include raw_message in /compose response (useful for debugging, leaks LLM output).
# COMPOSE_DEBUG=false

# ---- Discord bot (run via `bun run bot:discord`) ----
# Discord bot token from developer portal.
DISCORD_BOT_TOKEN=

# beauty-swarm API key the bot uses to call /chat etc.
BOT_API_KEY=bpc_...

# Base URL the bot hits (default: http://localhost:3000).
API_BASE_URL=http://localhost:3000
